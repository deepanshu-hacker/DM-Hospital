{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Patient medical appointment booking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "patientName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string" },
        "department": { "type": "string" },
        "doctor": { "type": "string" },
        "message": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["pending", "confirmed", "completed", "cancelled"] 
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "patientName", "email", "phone", "date", "department", "doctor", "status", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin user record",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "admins/{adminId}": {
      "schema": "Admin",
      "description": "Admin users"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment bookings"
    }
  }
}
